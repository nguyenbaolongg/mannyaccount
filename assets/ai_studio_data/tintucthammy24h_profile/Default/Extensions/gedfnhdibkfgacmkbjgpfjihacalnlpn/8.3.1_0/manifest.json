{
   "action": {
      "default_title": "Open Auto Whisk"
   },
   "background": {
      "service_worker": "background.js"
   },
   "default_locale": "en",
   "description": "__MSG_extDescription__",
   "host_permissions": [ "https://labs.google/*", "https://aisandbox-pa.googleapis.com/*", "https://autowhisk.dangduc131.workers.dev/*" ],
   "icons": {
      "128": "images/icon128.png",
      "16": "images/icon16.png",
      "48": "images/icon48.png"
   },
   "key": "",
   "manifest_version": 3,
   "name": "__MSG_extName__",
   "permissions": [ "sidePanel", "activeTab", "scripting", "storage", "tabs", "downloads" ],
   "side_panel": {
      "default_path": "gateway.html"
   },
   "update_url": "https://clients2.google.com/service/update2/crx",
   "version": "8.3.1",
   "web_accessible_resources": [ {
      "matches": [ "\u003Call_urls>" ],
      "resources": [ "images/*.png" ]
   } ]
}
