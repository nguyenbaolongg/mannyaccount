
import React, { useState, useEffect } from 'react';
import { VideoScriptResponse } from '../types';
import * as XLSX from 'xlsx';

interface ResultDisplayProps {
  result: VideoScriptResponse;
  articleUrl: string; // Trong mode link là URL bài báo, trong mode clone là tên option
}

export const ResultDisplay: React.FC<ResultDisplayProps> = ({ result, articleUrl }) => {
  const DEFAULT_SHEET_URL = "https://docs.google.com/spreadsheets/d/1aqpk5gCoStCWF1onBMrxujUeNamxBnL7puLOloweHLE/edit?gid=0#gid=0";
  const DEFAULT_SCRIPT_URL = "https://script.google.com/macros/s/AKfycbxFZnuTlv-NQp_-9B5VcHv494VeB9qsp2hHPuK5f83qXvt-A0c4Zl8ronZm2mEBkl74/exec";

  const [scriptUrl, setScriptUrl] = useState(DEFAULT_SCRIPT_URL);
  const [sheetUrl, setSheetUrl] = useState(DEFAULT_SHEET_URL);
  const [isSaving, setIsSaving] = useState(false);
  const [saveStatus, setSaveStatus] = useState<'idle' | 'success' | 'error'>('idle');
  const [showConfig, setShowConfig] = useState(false);
  const [originalVideoLink, setOriginalVideoLink] = useState(''); 
  
  // State cho các trường có thể chỉnh sửa
  const [editableTitle, setEditableTitle] = useState(result.video_title);
  const [editableTiktokTitle, setEditableTiktokTitle] = useState(result.title_tiktok);
  const [editableScript, setEditableScript] = useState(result.voice_script);
  const [editableTiktokId, setEditableTiktokId] = useState(result.tiktok_id || '');

  // State cho ngày giờ lưu bài
  const [selectedDateTime, setSelectedDateTime] = useState(() => {
    const now = new Date();
    const offset = now.getTimezoneOffset() * 60000;
    const localISOTime = new Date(now.getTime() - offset).toISOString().slice(0, 16);
    return localISOTime;
  });

  useEffect(() => {
    const savedScriptUrl = localStorage.getItem('googleSheetScriptUrl');
    if (savedScriptUrl) setScriptUrl(savedScriptUrl);

    const savedSheetUrl = localStorage.getItem('googleSheetViewUrl');
    if (savedSheetUrl) setSheetUrl(savedSheetUrl);
  }, []);

  useEffect(() => {
    setEditableTitle(result.video_title);
    setEditableTiktokTitle(result.title_tiktok);
    setEditableScript(result.voice_script);
    setEditableTiktokId(result.tiktok_id || '');
  }, [result]);

  const handleScriptUrlChange = (e: React.ChangeEvent<HTMLInputElement>) => {
    const val = e.target.value;
    setScriptUrl(val);
    localStorage.setItem('googleSheetScriptUrl', val);
  };

  const handleSheetUrlChange = (e: React.ChangeEvent<HTMLInputElement>) => {
    const val = e.target.value;
    setSheetUrl(val);
    localStorage.setItem('googleSheetViewUrl', val);
  };

  const getFormattedDateTime = (isoString: string) => {
    const date = new Date(isoString);
    const d = String(date.getDate()).padStart(2, '0');
    const m = String(date.getMonth() + 1).padStart(2, '0');
    const y = date.getFullYear();
    const h = String(date.getHours()).padStart(2, '0');
    const min = String(date.getMinutes()).padStart(2, '0');
    return `${d}/${m}/${y} ${h}:${min}`;
  };

  const getCombinedVisualHints = () => {
    if (!result.scene_breakdown || result.scene_breakdown.length === 0) return "";
    return result.scene_breakdown
      .map(scene => `[Cảnh ${scene.scene}]: ${scene.visual_hint || ""}`.trim())
      .filter(hint => hint.length > 0)
      .join('\n\n');
  };

  const handleExportExcel = () => {
    const combinedHints = getCombinedVisualHints();
    const formattedTime = getFormattedDateTime(selectedDateTime);
    
    // Cấu trúc dataRow (A-N)
    const dataRow = [
      articleUrl,                          // A: Link bài báo (1)
      editableTitle,                       // B: Tiêu đề video (2)
      editableScript,                      // C: Kịch bản đọc (3)
      "",                                  // D: Link file âm thanh (4)
      formattedTime,                       // E: Thời gian lưu (5)
      "",                                  // F: Ghi chú (6)
      originalVideoLink,                   // G: Link video gốc (7)
      combinedHints,                       // H: Gợi ý hình ảnh (8)
      "",                                  // I: Trống (9)
      editableTiktokTitle,                 // J: Tiêu đề TikTok (10)
      "",                                  // K: Trống (11)
      "",                                  // L: Trống (12)
      "",                                  // M: Trạng thái (13)
      editableTiktokId                     // N: TikTok ID (14)
    ];

    const wb = XLSX.utils.book_new();
    const headers = [
      "Link bài báo", "Tiêu đề video", "Kịch bản đọc", "Link âm thanh", "Thời gian", 
      "Ghi chú", "Link video gốc", "Gợi ý hình ảnh", "Trống", "Tiêu đề TikTok", 
      "Trống K", "Trống L", "Trạng thái", "TikTok ID"
    ];
    
    const ws = XLSX.utils.aoa_to_sheet([headers, dataRow]);
    
    ws['!cols'] = [
      { wch: 30 }, { wch: 40 }, { wch: 60 }, { wch: 20 },
      { wch: 25 }, { wch: 20 }, { wch: 40 }, { wch: 100 },
      { wch: 10 }, { wch: 40 }, { wch: 10 }, { wch: 10 },
      { wch: 15 }, { wch: 20 }
    ];
    
    XLSX.utils.book_append_sheet(wb, ws, "Kịch bản NewsGen");
    const fileName = `NewsGen_${editableTitle.substring(0, 20)}_${new Date().toISOString().slice(0,10)}.xlsx`;
    XLSX.writeFile(wb, fileName);
  };

  const handleSaveToSheet = async () => {
    if (!scriptUrl) { setShowConfig(true); return; }
    setIsSaving(true);
    setSaveStatus('idle');

    const combinedHints = getCombinedVisualHints();
    const formattedTime = getFormattedDateTime(selectedDateTime);
    
    const payload: any = {
      action: "save", 
      link: articleUrl,                 
      title: editableTitle,         
      script: editableScript,       
      audio_link: "",                   
      timestamp: formattedTime, 
      note: "",                         // Trả về trống cho cột F
      tiktok_id: editableTiktokId,      // Apps Script sẽ lưu vào cột N (cột 14)
      original_video: originalVideoLink, 
      combined_hints: combinedHints,
      title_tiktok: editableTiktokTitle 
    };

    try {
      await fetch(scriptUrl, {
        method: "POST", 
        mode: "no-cors", 
        headers: { "Content-Type": "text/plain;charset=utf-8" },
        body: JSON.stringify(payload),
      });
      
      setSaveStatus('success');
      setTimeout(() => setSaveStatus('idle'), 5000);
    } catch (error) {
      console.error("Lỗi lưu sheet:", error);
      setSaveStatus('error');
    } finally {
      setIsSaving(false);
    }
  };

  return (
    <div className="space-y-8 animate-in fade-in slide-in-from-bottom-4 duration-500">
      
      {/* 1. Editable Headers Section */}
      <div className="bg-white p-6 rounded-2xl shadow-sm border border-slate-200 space-y-6">
        <div className="flex justify-between items-start gap-4">
          <div className="flex-grow space-y-4">
            {/* Video Title Edit */}
            <div className="space-y-1">
              <label className="text-[10px] font-bold text-slate-400 uppercase tracking-widest ml-1">Tiêu đề chính (Cột B) - KHÔNG EMOJI</label>
              <input 
                type="text"
                value={editableTitle}
                onChange={(e) => setEditableTitle(e.target.value)}
                className="w-full text-xl font-bold text-slate-900 bg-slate-50 border border-slate-200 rounded-xl px-4 py-2 focus:ring-2 focus:ring-red-500 focus:bg-white transition-all outline-none"
                placeholder="Nhập tiêu đề video..."
              />
            </div>

            {/* TikTok Title Edit */}
            <div className="space-y-1">
              <label className="text-[10px] font-bold text-pink-500 uppercase tracking-widest ml-1">TikTok Title & Hooks (Cột J) - TUYỆT ĐỐI KHÔNG EMOJI/ICON</label>
              <div className="relative">
                <div className="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none text-pink-500 font-bold">#</div>
                <input 
                  type="text"
                  value={editableTiktokTitle}
                  onChange={(e) => setEditableTiktokTitle(e.target.value)}
                  className="w-full pl-8 pr-4 py-2 bg-pink-50 border border-pink-100 rounded-xl text-pink-700 font-bold text-sm focus:ring-2 focus:ring-pink-500 focus:bg-white transition-all outline-none"
                  placeholder="Tiêu đề TikTok thuần văn bản..."
                />
              </div>
            </div>
          </div>

          <button onClick={() => setShowConfig(!showConfig)} className="p-2 rounded-full text-slate-400 hover:text-slate-600 hover:bg-slate-100 transition-colors shrink-0">
             <svg className="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} /><path d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} /></svg>
          </button>
        </div>

        <div className="flex flex-wrap gap-2 pt-2 border-t border-slate-100">
          {result.keywords.map((kw, i) => (
            <span key={i} className="px-3 py-1 bg-blue-50 text-blue-700 text-[10px] font-bold rounded-full border border-blue-100 uppercase tracking-tighter">#{kw}</span>
          ))}
        </div>
      </div>

      {/* DateTime and IDs Selection */}
      <div className="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div className="bg-white p-6 rounded-2xl shadow-sm border border-slate-200 space-y-3">
          <div className="flex items-center gap-2">
            <div className="w-8 h-8 bg-emerald-600 text-white rounded-full flex items-center justify-center font-bold text-xs shadow-sm">
              <svg className="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} /></svg>
            </div>
            <h4 className="text-sm font-bold text-emerald-900 uppercase tracking-wider">Thời gian (Cột E)</h4>
          </div>
          <input 
            type="datetime-local" 
            value={selectedDateTime}
            onChange={(e) => setSelectedDateTime(e.target.value)}
            className="w-full px-4 py-3 rounded-xl border-2 border-emerald-50 focus:border-emerald-500 focus:ring-0 outline-none text-sm transition-all bg-emerald-50/30 text-black font-medium"
          />
          <p className="text-[10px] text-emerald-600 italic">Hiển thị: <span className="font-bold">{getFormattedDateTime(selectedDateTime)}</span></p>
        </div>

        <div className="bg-white p-6 rounded-2xl shadow-sm border border-slate-200 space-y-3">
          <div className="flex items-center gap-2">
            <div className="w-8 h-8 bg-indigo-600 text-white rounded-full flex items-center justify-center font-bold text-xs shadow-sm">
              <span className="font-bold">ID</span>
            </div>
            <h4 className="text-sm font-bold text-indigo-900 uppercase tracking-wider">TikTok ID (Cột N)</h4>
          </div>
          <input 
            type="text" 
            value={editableTiktokId}
            onChange={(e) => setEditableTiktokId(e.target.value)}
            placeholder="TikTok ID..."
            className="w-full px-4 py-3 rounded-xl border-2 border-indigo-50 focus:border-indigo-500 focus:ring-0 outline-none text-sm transition-all bg-indigo-50/30 text-black font-medium"
          />
        </div>
      </div>

      {result.clone_option && (
        <div className="bg-indigo-50 border border-indigo-200 p-6 rounded-2xl shadow-sm space-y-3">
          <div className="flex items-center gap-2">
            <div className="w-8 h-8 bg-indigo-600 text-white rounded-full flex items-center justify-center font-bold text-xs shadow-sm">
              <svg className="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.826L10.172 13.828a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1" strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} /></svg>
            </div>
            <h4 className="text-sm font-bold text-indigo-900 uppercase tracking-wider">Link video gốc (Cột G)</h4>
          </div>
          <input 
            type="text" 
            value={originalVideoLink}
            onChange={(e) => setOriginalVideoLink(e.target.value)}
            placeholder="Dán link video TikTok/Reels..."
            className="w-full px-4 py-3 rounded-xl border-2 border-indigo-100 focus:border-indigo-500 focus:ring-0 outline-none text-sm transition-all bg-white text-black"
          />
        </div>
      )}

      {/* Action Bar */}
      <div className="bg-white p-4 rounded-xl shadow-sm border border-slate-200 flex flex-col md:flex-row justify-between items-center gap-4 sticky top-4 z-20">
         <div className="flex items-center gap-3">
            <a href={sheetUrl} target="_blank" rel="noopener noreferrer" className="text-sm font-medium text-green-700 hover:text-green-800 flex items-center gap-2 px-4 py-2 bg-green-50 rounded-lg border border-green-100 transition-colors">Xem danh sách</a>
         </div>
         <div className="flex items-center gap-3 w-full md:w-auto">
            <button onClick={handleExportExcel} className="px-6 py-2 rounded-lg font-semibold text-sm transition-colors bg-slate-100 text-slate-700 hover:bg-slate-200">Xuất Excel</button>
            <button 
              onClick={() => handleSaveToSheet()} 
              disabled={isSaving} 
              className={`px-6 py-2 rounded-lg font-bold text-sm shadow-md transition-all text-white ${isSaving ? 'bg-green-400' : 'bg-green-600 hover:bg-green-700'}`}
            >
                {isSaving ? 'Đang lưu...' : saveStatus === 'success' ? 'Đã lưu!' : 'Lưu vào Sheet'}
            </button>
         </div>
      </div>
      
      {/* 2. Content Grid (Editable Script) */}
      <div className="grid grid-cols-1 lg:grid-cols-3 gap-8">
        <div className="lg:col-span-1 space-y-4">
          <div className="flex items-center justify-between">
            <h4 className="text-sm font-bold text-slate-500 uppercase tracking-widest">Kịch bản (Cột C) - KHÔNG EMOJI</h4>
          </div>
          <textarea 
            value={editableScript}
            onChange={(e) => setEditableScript(e.target.value)}
            className="w-full h-[600px] bg-slate-900 text-slate-200 p-6 rounded-2xl shadow-xl leading-relaxed font-medium overflow-y-auto custom-scrollbar whitespace-pre-wrap outline-none focus:ring-2 focus:ring-red-500 border border-slate-700"
            placeholder="Kịch bản không emoji..."
          />
        </div>

        <div className="lg:col-span-2 space-y-4">
          <h4 className="text-sm font-bold text-slate-500 uppercase tracking-widest">Chi tiết phân cảnh - KHÔNG EMOJI</h4>
          <div className="space-y-4">
            {result.scene_breakdown.map((scene) => (
              <div key={scene.scene} className="bg-white border border-slate-200 rounded-2xl p-5 shadow-sm flex flex-col md:flex-row gap-6 hover:border-slate-300 transition-colors">
                <div className="flex-shrink-0 flex items-center justify-center w-10 h-10 rounded-full bg-slate-100 text-slate-600 font-bold border border-slate-200">
                  {scene.scene}
                </div>
                <div className="flex-grow space-y-3">
                  <p className="text-slate-800 font-medium leading-relaxed">{scene.text}</p>
                  <div className="bg-slate-50 p-4 rounded-xl border border-slate-100">
                    <span className="text-[10px] font-bold text-slate-400 uppercase tracking-wider block mb-2">Gợi ý hình ảnh (Không emoji)</span>
                    <p className="text-sm italic text-slate-600 whitespace-pre-wrap">{scene.visual_hint}</p>
                  </div>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  );
};
